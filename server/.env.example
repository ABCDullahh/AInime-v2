# PostgreSQL connection string (Supabase, Neon, local, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/anime_compass?schema=public"

# Server port
PORT=3001

# Firebase service account JSON file path
# Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT="./firebase-service-account.json"

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3232

# Google Gemini API Key for AI recommendations
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
